# =============================================================================
# Docker 容器（如 football-app）内简化命令：把下面块复制为容器里任一路径的 .env 即可
# config 会依次加载：仓库根目录/.env、本目录/.env（仓库根 = football-betting-pipeline 的上一级）
# 例如代码在 /app/football-betting-pipeline/ 时，可创建 /app/.env 或 /app/football-betting-pipeline/.env
# 之后只需：docker exec -it football-app python football-betting-pipeline/run_real.py
# =============================================================================
# WORK_SPACE=/app
# CRAWLER_DOWNLOAD_DIR=/app/football-betting-data
# CRAWLER_REPORT_DIR=/app/football-betting-report
# CRAWLER_DEBUG_LOG_DIR=/app/football-betting-log
# CRAWLER_CHROME_BINARY=/usr/bin/chromium
# 留空 = 用 webdriver-manager 按 Chromium 版本下载驱动（勿写错成系统旧 chromedriver）
# CRAWLER_CHROMEDRIVER_PATH=
# CHROMEDRIVER_PATH=
# DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@football-db:3306/football_betting
# =============================================================================

# 与 football-betting-platform 共用同一 MySQL 时填写，供 evaluation_matches 入表/出表（plot_car、crawl_final）
# DATABASE_URL=mysql+pymysql://YOUR_USER:YOUR_PASSWORD@127.0.0.1:3306/football_betting

# 工作目录（可选）：其下放置 football-betting-data、football-betting-report、football-betting-log 等
# WORK_SPACE=/Users/zhiwuzou/Documents/cursor

# 跨天时间临界点（时，0～23）。该时及之后→当日文件夹；该时之前→前一日文件夹。默认 12
# CRAWLER_CUTOFF_HOUR=12

# 可选：下载目录、报告目录、时区等（不设则使用 WORK_SPACE 下的默认子目录）
# CRAWLER_DOWNLOAD_DIR=/path/to/北单
# CRAWLER_REPORT_DIR=/path/to/football-betting-report
# CRAWLER_TIMEZONE=Asia/Tokyo
# CRAWLER_HEADLESS=1

# 爬虫 Chrome：默认已使用「桌面版 Chrome」UA（避免 HeadlessChrome 被站点拒绝）；可完全覆盖
# CRAWLER_CHROME_USER_AGENT=Mozilla/5.0 ...
# 与 curl HTTP/2 报错类问题时可试：CRAWLER_CHROME_DISABLE_HTTP2=1
# Docker：apt 安装 chromium + chromium-driver 后指定路径，避免 webdriver-manager 的 chromedriver 缺库退出 127
# CRAWLER_CHROME_BINARY=/usr/bin/chromium
# CRAWLER_CHROMEDRIVER_PATH=/usr/bin/chromedriver
# Docker 内找不到 middle→ScoreDiv 内主表时可试：CRAWLER_ALLOW_GLOBAL_TABLE_LIVE=1
# 页面慢：CRAWLER_WAIT_ELEMENT=45
# 首屏 driver.get 读超时（阿里云常见）：默认已 eager + 240s，一般不必改
# CRAWLER_PAGE_LOAD_STRATEGY=eager
# CRAWLER_SELENIUM_READ_TIMEOUT=300

# 日志目录与保留天数（可选）
# CRAWLER_DEBUG_LOG_DIR=/path/to/football-betting-log
# CRAWLER_LOG_RETENTION_DAYS=7

# run_real 列表过滤（可选）：可视、状态；联赛白名单见 config.py 中 CRAWLER_TARGET_LEAGUES
# CRAWLER_MATCH_FILTER_VISIBLE_ONLY=1
# CRAWLER_MATCH_STATUS_MODES=not_started
# 示例：同时抓未开场 + 进行中 + 完场
# CRAWLER_MATCH_STATUS_MODES=not_started,live,finished

# 调试用：正式跑全量时请勿设置或保持注释
# CRAWLER_DEBUG_MAX_MATCHES=3
# CRAWLER_DEBUG_MATCH_KEYWORDS=帕纳辛纳科斯,里尔,博洛尼亚

# MySQL（必填）请把 YOUR_MYSQL_USER 和 YOUR_MYSQL_PASSWORD 改成你本机的 MySQL 用户名和密码
DATABASE_URL=mysql+pymysql://YOUR_MYSQL_USER:YOUR_MYSQL_PASSWORD@localhost:3306/football_betting

# JWT 密钥（必填，用于登录 token）
JWT_SECRET_KEY=请改为随机长字符串

# 短信配置（发送验证码）
# 开发时可留空，使用“模拟发送”（控制台输出验证码）
# 生产环境填写具体厂商的 key/secret，见 README
SMS_PROVIDER=mock
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# 验证码有效期（秒）
SMS_CODE_EXPIRE=300

# 工作目录（可选）：与 pipeline 的 WORK_SPACE 一致时，曲线图目录默认为 WORK_SPACE/football-betting-report
# WORK_SPACE=/Users/zhiwuzou/Documents/cursor

# 曲线图目录（不设则使用 WORK_SPACE/football-betting-report）
# CURVE_IMAGE_DIR=/path/to/football-betting-report

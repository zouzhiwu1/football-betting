#!/usr/bin/env bash
# 统一管理：仅适用于带 systemd 的 Linux（生产机）。macOS 开发请用 ./scripts/run.sh
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
WORK_ROOT="$(cd "${ROOT}/.." && pwd)"
SERVICE="football-betting-platform"
LOG="${WORK_ROOT}/football-betting-log/platform_$(date +%Y%m%d).log"

abort_not_systemd_linux() {
  if command -v systemctl >/dev/null 2>&1; then
    return 0
  fi
  cat <<EOF >&2
未检测到 systemctl（本机多半是 macOS / 非 systemd 环境）。

  • 本地开发：不要用 install / restart。在 football-betting-platform 目录执行:
      ./scripts/run.sh
    或:  .venv/bin/python run.py

  • Linux 云服务器（如阿里云 ECS）：把项目拉到那台机器上再执行:
      sudo ./scripts/server install
EOF
  exit 1
}

usage() {
  cat <<EOF
用法: ./scripts/server <命令>   （仅 Linux + systemd 生产机；mac 请看 develop 说明）

  install   安装/更新 systemd 并重启（仅路径或 scripts/*.service.example 有变时需要）
  start     后台启动
  stop      停止
  restart   重启（改代码、pip install 后用这个；不要每次报错都 reinstall）
  status    运行状态
  logs      跟踪日志文件: $LOG
  journal   systemd 日志: journalctl -u $SERVICE -f

首次部署:
  chmod +x scripts/server
  sudo ./scripts/server install

日常:
  sudo ./scripts/server restart
  ./scripts/server logs

日志目录与 pipeline 一致: <仓库根>/football-betting-log/platform_YYYYMMDD.log
EOF
}

ensure_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    exec sudo -E "$0" "$@"
  fi
}

case "${1:-}" in
  install)
    abort_not_systemd_linux
    ensure_root "$@"
    exec "${SCRIPT_DIR}/install-systemd.sh"
    ;;
  start)
    abort_not_systemd_linux
    ensure_root "$@"
    systemctl start "$SERVICE"
    echo "已启动。日志: $LOG"
    ;;
  stop)
    abort_not_systemd_linux
    ensure_root "$@"
    systemctl stop "$SERVICE"
    ;;
  restart)
    abort_not_systemd_linux
    ensure_root "$@"
    systemctl restart "$SERVICE"
    echo "已重启。日志: $LOG"
    ;;
  status)
    abort_not_systemd_linux
    systemctl status "$SERVICE" --no-pager || true
    ;;
  logs)
    mkdir -p "$(dirname "$LOG")"
    if [[ ! -f "$LOG" ]]; then
      echo "尚无 $LOG（若开发机请先: cd \"$ROOT\" && ./scripts/run.sh 跑一次）" >&2
      if command -v systemctl >/dev/null 2>&1; then
        echo "生产机可: sudo $ROOT/scripts/server restart 或 journal: ./scripts/server journal" >&2
      fi
      touch "$LOG" 2>/dev/null || true
    fi
    tail -f "$LOG"
    ;;
  journal)
    abort_not_systemd_linux
    if ! command -v journalctl >/dev/null 2>&1; then
      echo "未找到 journalctl" >&2
      exit 1
    fi
    journalctl -u "$SERVICE" -f
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "未知命令: ${1:-}" >&2
    usage
    exit 1
    ;;
esac

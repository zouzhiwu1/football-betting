.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  min-height: 0;
  padding: 16rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.form {
  padding: 20rpx;
  margin-bottom: 12rpx;
}

/* 查询区按 mobile 紧凑化：覆盖全局大号 input/button */
.form .label {
  font-size: 24rpx;
  margin-top: 10rpx;
  margin-bottom: 6rpx;
}

.form .input {
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
  font-size: 28rpx;
}

.form .btn-primary {
  margin-top: 16rpx;
  padding: 14rpx;
  font-size: 30rpx;
}

.results-scroll {
  flex: 1;
  min-height: 0;
}

.inline-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.img-card {
  padding: 12rpx;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f9fafb;
  margin-bottom: 8rpx;
}

.img {
  width: 100%;
  display: block;
  background: #050816;
  border-radius: 12rpx;
}

.img-err {
  padding: 40rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
}

<view class="page">
  <view class="form card">
    <view class="label">日期</view>
    <picker mode="date" value="{{pickerDate}}" bindchange="onDate">
      <view class="input">{{pickerDate || '请选择日期'}}</view>
    </picker>

    <view class="label">球队名（选填，主或客，模糊匹配）</view>
    <input class="input" value="{{team}}" placeholder="留空则查询当天全部" bindinput="onTeam" />

    <view class="btn-primary {{searching ? 'disabled' : ''}}" bindtap="onSearch">
      {{searching ? '搜索中…' : '搜索'}}
    </view>
    <view wx:if="{{inlineHint}}" class="inline-hint">{{inlineHint}}</view>
  </view>

  <scroll-view
    scroll-y
    class="results-scroll"
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="onReachResultBottom"
    lower-threshold="120"
  >
    <view wx:for="{{items}}" wx:key="k" class="card img-card">
      <view class="card-title">{{item.home}} VS {{item.away}}</view>
      <image wx:if="{{item.localPath}}" class="img" src="{{item.localPath}}" mode="widthFix" />
      <view wx:elif="{{item.loadError}}" class="img-err">图片加载失败（请检查登录与域名）</view>
      <view wx:else class="img-err">加载中…</view>
    </view>
    <view wx:if="{{loadingMore}}" class="inline-hint">加载更多中...</view>
    <view wx:elif="{{loadedCount < allItems.length}}" class="inline-hint">下滑加载更多</view>
  </scroll-view>
</view>

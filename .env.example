# =============================================================================
# football-betting 仓库根目录环境变量（总配置）
# -----------------------------------------------------------------------------
# 用法：复制为 .env 后按本机修改（勿提交含真实密码的 .env）
#   cp .env.example .env
# platform / pipeline 会优先加载仓库根目录 .env，再加载各自子目录下的 .env（仅补充未定义的键）。
# =============================================================================

# ----- MySQL（platform + pipeline 共用；pipeline 写 evaluation_matches 等）-----
# 以下为本地开发示例；生产请改为真实账号或使用占位符 YOUR_MYSQL_USER 会触发 platform 配置校验提示
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/football_betting

# ----- football-betting-platform（用户后端）-----
JWT_SECRET_KEY=dev-football-betting-jwt-secret-at-least-32-chars-long
PORT=5001

# 短信验证码：开发用 mock（验证码打印在 run.py 终端）
SMS_PROVIDER=mock
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=
SMS_CODE_EXPIRE=300

# 工作目录：与 pipeline 一致时，曲线图默认可用 WORK_SPACE/football-betting-report
# WORK_SPACE=/Users/you/Documents/cursor

# 曲线图根目录（默认 WORK_SPACE/football-betting-report 或仓库旁 football-betting-report）
# CURVE_IMAGE_DIR=

# 1=仅有效会员可看曲线（默认）；0=按设计书非会员可看完场/历史
# CURVES_REQUIRE_ACTIVE_MEMBERSHIP=1

# 平台日志（可选）
# LOG_DIR=
# LOG_FILE=

# ----- 支付宝（会员购买回调）-----
# mock=本地联调不验签；rsa=生产验签（需公钥）
ALIPAY_MODE=mock
ALIPAY_APP_ID=
ALIPAY_MOCK_SECRET=
# ALIPAY_PUBLIC_KEY_PATH=/path/to/alipay_public_key.pem
# ALIPAY_PUBLIC_KEY_PEM=
PUBLIC_BASE_URL=http://127.0.0.1:5001

# ----- 微信支付（会员购买回调）-----
WECHAT_PAY_MODE=mock
WECHAT_MOCK_SECRET=
WECHAT_API_KEY=

# 会员标价覆盖（JSON，可选）
# MEMBERSHIP_PRICES_JSON={"week":"9.90","month":"29.90","quarter":"79.90","year":"299.90"}

# ----- football-betting-pipeline（爬虫 / 报表 / 出图）-----
# 未设置时 pipeline 内仍有本地默认；与 platform 共用库时请与上 DATABASE_URL 一致

# 爬虫入口页
# CRAWLER_BASE_URL=https://live.nowscore.com/2in1.aspx

# 数据与报告目录（默认在 WORK_SPACE 下）
# CRAWLER_DOWNLOAD_DIR=
# CRAWLER_REPORT_DIR=

# 跨日临界点（时 0～23），默认 12
# CRAWLER_CUTOFF_HOUR=12

# 定时触发整点（逗号分隔）
# CRAWLER_TRIGGER_HOURS=2,4,6,13,15,17,19,21,23

# CRAWLER_TIMEZONE=Asia/Tokyo
# CRAWLER_HEADLESS=1
# CRAWLER_CHROME_USER_AGENT=（可选，覆盖默认桌面 Chrome UA）
# CRAWLER_CHROME_DISABLE_HTTP2=1

# CRAWLER_DEBUG_LOG_DIR=
# CRAWLER_LOG_RETENTION_DAYS=7

# 调试：限制场数 / 关键词（正式跑全量请注释）
# CRAWLER_DEBUG_MAX_MATCHES=0
# CRAWLER_DEBUG_MATCH_KEYWORDS=

# 联赛白名单：设为空字符串表示不限制
# CRAWLER_TARGET_LEAGUES=

# run_real 列表过滤
# CRAWLER_MATCH_FILTER_VISIBLE_ONLY=1
# CRAWLER_MATCH_STATUS_MODES=not_started

# CRAWLER_EXPORT_EXCEL_MAX_ATTEMPTS=3
